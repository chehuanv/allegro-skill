; ============================================================
; 文件名: create_parm_form.form
; 功能说明: 图标 - 参数创建表单定义
; 编码格式: GBK (简体中文)
; 注意事项: 本文件使用GBK编码保存，请勿用UTF-8编码打开
; ============================================================
FILE_TYPE=FORM_DEFN VERSION=2
FORM
FIXED
PORT 24 50
HEADER "Diff Via Anti Pad"

POPUP <class>"class"
POPUP <subclass>"subclass"
TILE

TEXT "Active Class and Subclass:"

TLOC 1 1
ENDTEXT

FIELD class
FLOC 5 4
ENUMSET 19
OPTIONS prettyprint
POP "class"
ENDFIELD

FIELD subcolor
FLOC 2 7
COLOR 2 1
OPTIONS colcrchooser
ENDFIELD

FIELD subclass
FLOC 5 7
ENUMSET 19
OPTIONS prettyprint ownerdrawn
POP "subclass"
ENDFIELD

TEXT "Expand size of vias (mils):"

TLOC 1 11
ENDTEXT

FIELD expandValue_via

FLOC 19 11

REALFILLIN 6 6

MIN 0

ENDFIELD

ENDTILE

ENDFORM
