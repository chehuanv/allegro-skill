FILE_TYPE=FORM_DEFN VERSION=2
FORM
FIXED
PORT 42 8
HEADER "Artwork Form"
TILE
TEXT "Form Name"
TLOC 1 1
ENDTEXT

FIELD form_name
FLOC 1 3
STRFILLIN 20 1024
ENDFIELD

FIELD create
FLOC 22 3
MENUBUTTON "创建" 10 3
ENDFIELD

TEXT "Description"
TLOC 1 5
ENDTEXT

FIELD description
FLOC 1 7
STRFILLIN 40 1024
ENDFIELD

ENDTILE
ENDFORM
