FILE_TYPE=FORM_DEFN VERSION=2
FORM
FIXED
PORT 42 12
HEADER "Find Dlines"
TILE
TEXT "Layer"
TLOC 1 1
ENDTEXT

FIELD layer
FLOC 1 3
ENUMSET 20
POP "layer_pop"
ENDFIELD

TEXT "Net"
TLOC 22 1
ENDTEXT

FIELD net
FLOC 22 3
STRFILLIN 20 1024
ENDFIELD

TEXT "Width"
TLOC 1 5
ENDTEXT

FIELD width
FLOC 1 7
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

TEXT "Tolerance"
TLOC 22 5
ENDTEXT

FIELD tolerance
FLOC 22 7
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

FIELD find
FLOC 1 10
MENUBUTTON "查找" 10 3
ENDFIELD

FIELD delete
FLOC 22 10
MENUBUTTON "删除" 10 3
ENDFIELD

ENDTILE
ENDFORM
