FILE_TYPE=FORM_DEFN VERSION=2
FORM
FIXED
PORT 42 12
HEADER "Symbol对齐"
TILE
TEXT "对齐方式"
TLOC 1 1
ENDTEXT

FIELD align_bottom
FLOC 1 3
MENUBUTTON forms/align-bottom.bmp 3 3
ENDFIELD

FIELD align_centerH
FLOC 5 3
MENUBUTTON forms/align-centerH.bmp 3 3
ENDFIELD

FIELD align_centerV
FLOC 9 3
MENUBUTTON forms/align-centerV.bmp 3 3
ENDFIELD

FIELD align_left
FLOC 13 3
MENUBUTTON forms/align-left.bmp 3 3
ENDFIELD

FIELD align_right
FLOC 17 3
MENUBUTTON forms/align-right.bmp 3 3
ENDFIELD

FIELD align_top
FLOC 21 3
MENUBUTTON forms/align-top.bmp 3 3
ENDFIELD

TEXT "参考对象"
TLOC 1 7
ENDTEXT

FIELD ref_obj
FLOC 1 9
ENUMSET 20
POP "ref_obj_pop"
ENDFIELD

FIELD apply
FLOC 22 9
MENUBUTTON "应用" 10 3
ENDFIELD

ENDTILE
ENDFORM
