FILE_TYPE=FORM_DEFN VERSION=2
FORM
FIXED
PORT 45 14
HEADER "Interactive Net Editor"
TILE
TEXT "Net Name"
TLOC 1 1
ENDTEXT

FIELD net_name
FLOC 1 3
STRFILLIN 25 1024
ENDFIELD

TEXT "Action"
TLOC 1 5
ENDTEXT

FIELD action
FLOC 1 7
ENUMSET 20
POP "action_pop"
ENDFIELD

TEXT "Value"
TLOC 1 9
ENDTEXT

FIELD value
FLOC 1 11
STRFILLIN 25 1024
ENDFIELD

FIELD apply
FLOC 1 13
MENUBUTTON "应用" 10 3
ENDFIELD

ENDTILE
ENDFORM
