FILE_TYPE=FORM_DEFN VERSION=2
FORM AUTOGREYTEXT
FIXED
PORT 69 10
HEADER "BMP Logo导入"
POPUP <fontlist_pop>""""
POPUP <layerclass_pop>""""
TILE
TEXT "BMP文件路径"
TLOC 1 1
ENDTEXT

FIELD bmpfile
FLOC 1 3
STRFILLIN 50 1024
ENDFIELD

FIELD browse
FLOC 52 3
MENUBUTTON "浏览..." 10 3
ENDFIELD

TEXT "字体选择"
TLOC 1 5
ENDTEXT

FIELD fontlist
FLOC 1 7
ENUMSET 20
POP "fontlist_pop"
ENDFIELD

TEXT "层选择"
TLOC 22 5
ENDTEXT

FIELD layerclass
FLOC 22 7
ENUMSET 20
POP "layerclass_pop"
ENDFIELD

TEXT "缩放比例"
TLOC 1 9
ENDTEXT

FIELD scale
FLOC 1 11
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

TEXT "线宽"
TLOC 22 9
ENDTEXT

FIELD linewidth
FLOC 22 11
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

FIELD preview
FLOC 1 14
CHECKLIST "预览"
ENDFIELD

FIELD import
FLOC 22 14
MENUBUTTON "导入" 10 3
ENDFIELD

ENDTILE
ENDFORM
