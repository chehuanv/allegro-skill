FILE_TYPE=FORM_DEFN VERSION=2
FORM
FIXED
PORT 42 8
HEADER "Auto Via"
TILE
TEXT "Via Type"
TLOC 1 1
ENDTEXT

FIELD via_type
FLOC 1 3
ENUMSET 20
POP "via_type_pop"
ENDFIELD

TEXT "Net"
TLOC 22 1
ENDTEXT

FIELD net
FLOC 22 3
STRFILLIN 20 1024
ENDFIELD

FIELD auto
FLOC 1 6
MENUBUTTON "自动" 10 3
ENDFIELD

ENDTILE
ENDFORM
