; ============================================================
; 文件名: colorsetting.form
; 功能说明: 表单 - 颜色设置表单定义
; 编码格式: GBK (简体中文)
; 注意事项: 本文件使用GBK编码保存，请勿用UTF-8编码打开
; ============================================================
FILE_TYPE=FORM_DEFN VERSION=2
FORM
FIXED
PORT 25 18
HEADER "Color Setting"
TILE

TEXT "Select color preset:"
TLOC 1 1
ENDTEXT

FIELD presetList
FLOC 1 3
ENUMSET 20
OPTIONS prettyprint
POP "colorPresets"
ENDFIELD

FIELD btnApply
FLOC 1 10
MENUBUTTON "Apply" 10 2
ENDFIELD

FIELD btnClose
FLOC 13 10
MENUBUTTON "Close" 10 2
ENDFIELD

ENDTILE
ENDFORM