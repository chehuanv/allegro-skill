; ============================================================
; 文件名: template.form
; 功能说明: 表单 - 模板表单定义
; 编码格式: GBK (简体中文)
; 注意事项: 本文件使用GBK编码保存，请勿用UTF-8编码打开
; ============================================================
FORM
FIXED
PORT 50 20
HEADER "AllegroSkillToolbox - Template"

TILE
TEXT "Parameter 1:"
TLOC 2 2
ENDTEXT

FIELD param1
FLOC 15 2
STRFILLIN 20 32
ENDFIELD

TEXT "Parameter 2:"
TLOC 2 5
ENDTEXT

FIELD param2
FLOC 15 5
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

FIELD btnOK
FLOC 2 10
MENUBUTTON "OK" 10 3
ENDFIELD

FIELD btnCancel
FLOC 15 10
MENUBUTTON "Cancel" 10 3
ENDFIELD

ENDTILE
ENDFORM
