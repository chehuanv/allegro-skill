FILE_TYPE=FORM_DEFN VERSION=2
FORM
FIXED
PORT 42 10
HEADER "QFP Pitch Calculator"
TILE
TEXT "Pin Count"
TLOC 1 1
ENDTEXT

FIELD pin_count
FLOC 1 3
INTFILLIN 5 5
ENDFIELD

TEXT "Body Size (mm)"
TLOC 1 5
ENDTEXT

FIELD body_size
FLOC 1 7
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

TEXT "Pitch (mm)"
TLOC 22 5
ENDTEXT

FIELD pitch
FLOC 22 7
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

FIELD calculate
FLOC 1 9
MENUBUTTON "计算" 10 3
ENDFIELD

ENDTILE
ENDFORM
