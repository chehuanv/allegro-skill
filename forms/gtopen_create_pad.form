FILE_TYPE=FORM_DEFN VERSION=2
FORM
FIXED
PORT 60 35
HEADER "创建焊盘"

TILE
TEXT "焊盘名称"
TLOC 1 1
ENDTEXT

FIELD pad_name
FLOC 1 3
STRFILLIN 20 1024
ENDFIELD

TEXT "焊盘类型"
TLOC 1 5
ENDTEXT

FIELD pad_type
FLOC 1 7
ENUMSET 20
POP "pad_type_pop"
ENDFIELD

TEXT "起始层"
TLOC 22 5
ENDTEXT

FIELD start_layer
FLOC 22 7
ENUMSET 20
POP "start_layer_pop"
ENDFIELD

TEXT "结束层"
TLOC 1 9
ENDTEXT

FIELD end_layer
FLOC 1 11
ENUMSET 20
POP "end_layer_pop"
ENDFIELD

TEXT "Regular Pad"
TLOC 1 13
ENDTEXT

FIELD reg_pad_shape
FLOC 1 15
ENUMSET 15
POP "reg_pad_shape_pop"
ENDFIELD

FIELD reg_pad_width
FLOC 18 15
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

FIELD reg_pad_height
FLOC 30 15
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

TEXT "Thermal Pad"
TLOC 1 17
ENDTEXT

FIELD therm_pad_shape
FLOC 1 19
ENUMSET 15
POP "therm_pad_shape_pop"
ENDFIELD

FIELD therm_pad_width
FLOC 18 19
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

FIELD therm_pad_height
FLOC 30 19
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

TEXT "Anti Pad"
TLOC 1 21
ENDTEXT

FIELD anti_pad_shape
FLOC 1 23
ENUMSET 15
POP "anti_pad_shape_pop"
ENDFIELD

FIELD anti_pad_width
FLOC 18 23
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

FIELD anti_pad_height
FLOC 30 23
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

TEXT "钻孔"
TLOC 1 25
ENDTEXT

FIELD drill_shape
FLOC 1 27
ENUMSET 15
POP "drill_shape_pop"
ENDFIELD

FIELD drill_width
FLOC 18 27
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

FIELD drill_height
FLOC 30 27
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

FIELD create
FLOC 1 30
MENUBUTTON "创建" 10 3
ENDFIELD

FIELD cancel
FLOC 22 30
MENUBUTTON "取消" 10 3
ENDFIELD

ENDTILE
ENDFORM
