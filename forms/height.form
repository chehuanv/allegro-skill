FILE_TYPE=FORM_DEFN VERSION=2
FORM
FIXED
PORT 35 18
HEADER "Component Height"
TILE
TEXT "Component"
TLOC 1 1
ENDTEXT

FIELD comp_name
FLOC 1 3
STRFILLIN 25 1024
ENDFIELD

TEXT "Height (mm)"
TLOC 1 5
ENDTEXT

FIELD height
FLOC 1 7
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

TEXT "Max Height"
TLOC 1 9
ENDTEXT

FIELD max_height
FLOC 1 11
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

TEXT "Min Height"
TLOC 1 13
ENDTEXT

FIELD min_height
FLOC 1 15
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

FIELD update
FLOC 1 17
MENUBUTTON "更新" 10 3
ENDFIELD

ENDTILE
ENDFORM
