
FILE_TYPE=FORM_DEFN VERSION=2
FORM AUTOGREYTEXT
FIXED
PORT 37 10
HEADER "导出Symbol"

TILE

TEXT "导出路径"
TLOC 1 1
ENDTEXT

FIELD export_path
FLOC 1 3
STRFILLIN 40 1024
ENDFIELD

FIELD browse
FLOC 42 3
MENUBUTTON "浏览..." 10 3
ENDFIELD

FIELD export
FLOC 1 6
MENUBUTTON "导出" 10 3
ENDFIELD

ENDTILE
ENDFORM
