; ============================================================
; 文件名: unitconvert.form
; 功能说明: 表单 - 单位转换表单定义
; 编码格式: GBK (简体中文)
; 注意事项: 本文件使用GBK编码保存，请勿用UTF-8编码打开
; ============================================================
FORM
FIXED
PORT 40 28
HEADER "Unit Converter"

TILE
TEXT "Input Value:"
TLOC 2 2
ENDTEXT

FIELD fInput
FLOC 15 2
REALFILLIN 12 12
DECIMAL 4
ENDFIELD

TEXT "From:"
TLOC 2 5
ENDTEXT

FIELD cmbFrom
FLOC 15 5
ENUMSET 12
OPTIONS "mils:mm:inch:micron:cm"
POP "mils"
ENDFIELD

TEXT "To:"
TLOC 2 8
ENDTEXT

FIELD cmbTo
FLOC 15 8
ENUMSET 12
OPTIONS "mils:mm:inch:micron:cm"
POP "mm"
ENDFIELD

FIELD btnConvert
FLOC 2 12
MENUBUTTON "Convert" 12 3
ENDFIELD

FIELD btnClose
FLOC 18 12
MENUBUTTON "Close" 10 3
ENDFIELD

TEXT "Result:"
TLOC 2 16
ENDTEXT

FIELD fOutput
FLOC 15 16
STRFILLIN 18 32
ENDFIELD

ENDTILE
ENDFORM
