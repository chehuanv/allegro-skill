FILE_TYPE=FORM_DEFN VERSION=2
FORM
FIXED
PORT 24 20
HEADER "Hilight SMD V1.0"
TILE
TEXT "Select Net"
TLOC 1 1
ENDTEXT

FIELD net_select
FLOC 1 3
ENUMSET 20
POP "net_select_pop"
ENDFIELD

TEXT "Highlight Color"
TLOC 1 5
ENDTEXT

FIELD color
FLOC 1 7
ENUMSET 15
POP "color_pop"
ENDFIELD

FIELD hilight
FLOC 1 10
MENUBUTTON "Highlight" 10 3
ENDFIELD

FIELD clear
FLOC 12 10
MENUBUTTON "Clear" 10 3
ENDFIELD

ENDTILE
ENDFORM
