FILE_TYPE=FORM_DEFN VERSION=2
FORM
FIXED
PORT 42 8
HEADER "Add Dynamic Shape"
TILE
TEXT "Net"
TLOC 1 1
ENDTEXT

FIELD net
FLOC 1 3
STRFILLIN 20 1024
ENDFIELD

TEXT "Layer"
TLOC 22 1
ENDTEXT

FIELD layer
FLOC 22 3
ENUMSET 20
POP "layer_pop"
ENDFIELD

FIELD add
FLOC 1 6
MENUBUTTON "添加" 10 3
ENDFIELD

ENDTILE
ENDFORM
