; ============================================================
; 文件名: gridchoose.form
; 功能说明: 表单 - 栅格选择表单定义
; 编码格式: GBK (简体中文)
; 注意事项: 本文件使用GBK编码保存，请勿用UTF-8编码打开
; ============================================================
FILE_TYPE=FORM_DEFN VERSION=2
FORM
FIXED
PORT 25 24
HEADER "Choose Grid"
TILE

TEXT "Select grid preset:"
TLOC 1 1
ENDTEXT

FIELD presetList
FLOC 1 3
ENUMSET 20
OPTIONS prettyprint
POP "gridPresets"
ENDFIELD

FIELD btnApply
FLOC 1 16
MENUBUTTON "Apply" 10 2
ENDFIELD

FIELD btnClose
FLOC 13 16
MENUBUTTON "Close" 10 2
ENDFIELD

ENDTILE
ENDFORM