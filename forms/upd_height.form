FILE_TYPE=FORM_DEFN VERSION=2
FORM
FIXED
PORT 50 21
HEADER "Update Front-End Height"
TILE
TEXT "Component"
TLOC 1 1
ENDTEXT

FIELD comp_name
FLOC 1 3
STRFILLIN 25 1024
ENDFIELD

TEXT "New Height (mm)"
TLOC 1 5
ENDTEXT

FIELD new_height
FLOC 1 7
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

TEXT "Max Height"
TLOC 1 9
ENDTEXT

FIELD max_height
FLOC 1 11
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

TEXT "Min Height"
TLOC 1 13
ENDTEXT

FIELD min_height
FLOC 1 15
REALFILLIN 10 10
DECIMAL 3
ENDFIELD

TEXT "Placement Side"
TLOC 1 17
ENDTEXT

FIELD side
FLOC 1 19
ENUMSET 15
POP "side_pop"
ENDFIELD

FIELD update
FLOC 22 19
MENUBUTTON "更新" 10 3
ENDFIELD

ENDTILE
ENDFORM
